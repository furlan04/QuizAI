{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "quiz.generated",
  "title": "QuizGeneratedEvent",
  "description": "Pubblicato dall'AI Agent Service su quiz.generated al termine della generazione.",
  "type": "object",
  "required": ["quiz_id", "status", "questions", "tags"],
  "additionalProperties": false,
  "properties": {
    "quiz_id": {
      "type": "string",
      "description": "Stesso ID ricevuto in QuizGenerateEvent, invariato."
    },
    "status": {
      "type": "string",
      "enum": ["ready", "failed"],
      "description": "Esito della generazione."
    },
    "questions": {
      "type": "array",
      "description": "Lista di domande generate. Vuota se status è failed.",
      "items": {
        "type": "object",
        "required": ["text", "options", "correct_index", "explanation"],
        "additionalProperties": false,
        "properties": {
          "text": {
            "type": "string",
            "description": "Testo della domanda."
          },
          "options": {
            "type": "array",
            "description": "Esattamente 4 opzioni di risposta.",
            "items": { "type": "string" },
            "minItems": 4,
            "maxItems": 4
          },
          "correct_index": {
            "type": "integer",
            "minimum": 0,
            "maximum": 3,
            "description": "Indice (0-3) dell'opzione corretta nell'array options."
          },
          "explanation": {
            "type": "string",
            "description": "Spiegazione del perché la risposta è corretta."
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "description": "Tag tematici derivati dal topic e dal piano di generazione.",
      "items": { "type": "string" }
    },
    "error": {
      "type": ["string", "null"],
      "description": "Messaggio di errore. Valorizzato solo se status è failed, null altrimenti."
    }
  }
}
