{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FRONTEND_URL": "http://localhost:3000",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "quiz-route": {
        "ClusterId": "quiz-cluster",
        "Match": {
          "Path": "/quiz/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/users/{**catch-all}"
        }
      },
      "ai-route": {
        "ClusterId": "ai-cluster",
        "Match": {
          "Path": "/ai/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      },
      "file-route": {
        "ClusterId": "file-cluster",
        "Match": {
          "Path": "/files/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://auth-service:5001" }
        }
      },
      "quiz-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://quiz-service:8080" }
        }
      },
      "user-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://user-service:5002" }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://ai-agent:8000" }
        }
      },
      "file-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://file-service:8001" }
        }
      }
    }
  }
}
