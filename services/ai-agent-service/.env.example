GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE_CONSUME=quiz.generate
RABBITMQ_QUEUE_PUBLISH=quiz.generated
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=quizai
INTERNAL_API_KEY=your_internal_key

# Browser Use — deep web search before quiz generation (opt-in via deep_search flag).
# Leave BROWSER_USE_API_KEY empty to disable deep search entirely.
BROWSER_USE_API_KEY=YOURKEY
# Optional overrides (defaults shown):
# BROWSER_USE_BASE_URL=https://api.browser-use.com
# BROWSER_USE_TIMEOUT=180
# BROWSER_USE_POLL_INTERVAL=3
